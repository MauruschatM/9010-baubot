# Local web app URL
SITE_URL=http://localhost:3001

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_APP_NAME=mvp-template

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=MVP Template <no-reply@example.com>
# Optional
RESEND_REPLY_TO=support@example.com

# Vercel AI Gateway + Mastra
AI_GATEWAY_API_KEY=replace-with-your-vercel-ai-gateway-api-key
# Optional (defaults to google/gemini-3.1-pro-preview)
AI_GATEWAY_MODEL=google/gemini-3.1-pro-preview

# Convex deployment values are populated by `bun run dev:setup`
# CONVEX_DEPLOYMENT=dev:your-project
# CONVEX_URL=https://your-project.convex.cloud
# CONVEX_SITE_URL=https://your-project.convex.site
