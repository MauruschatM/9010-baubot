# Local web app URL
SITE_URL=http://localhost:3001

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_APP_NAME=mvp-template

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=MVP Template <no-reply@example.com>
# Optional
RESEND_REPLY_TO=support@example.com

# Vercel AI Gateway + Mastra
AI_GATEWAY_API_KEY=replace-with-your-vercel-ai-gateway-api-key
# Optional (defaults to google/gemini-3.1-pro)
AI_GATEWAY_MODEL=google/gemini-3.1-pro
# Optional (turn detection + lightweight WhatsApp classification; defaults to google/gemini-3-flash)
AI_GATEWAY_TURN_MODEL=google/gemini-3-flash

# Groq (required for WhatsApp voice/video transcription)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# Twilio (required for WhatsApp webhook + outbound replies)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM_NUMBER=whatsapp:+14155238886
# Optional but recommended for signature verification behind proxies
TWILIO_WEBHOOK_URL=https://your-convex-site.convex.site/webhooks/whatsapp/twilio

# WhatsApp Agent setup
WHATSAPP_AGENT_NUMBER=+14155238886
WHATSAPP_INITIAL_MESSAGE=Hi!

# Convex deployment values are populated by `bun run dev:setup`
# CONVEX_DEPLOYMENT=dev:your-project
# CONVEX_URL=https://your-project.convex.cloud
# CONVEX_SITE_URL=https://your-project.convex.site
